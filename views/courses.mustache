{{> head}}
{{> header}}
<main>
    <h1>Courses</h1>

    <section>
        <form class="filter-form" method="get" action="/courses">
            <label>Level
                <select name="level">
                    <option value="">Any</option>
                    <option value="beginner">Beginner</option>
                    <option value="intermediate">Intermediate</option>
                    <option value="advanced">Advanced</option>
                </select>
            </label>
            <label>Type
                <select name="type">
                    <option value="">Any</option>
                    <option value="WEEKLY_BLOCK">Weekly Block</option>
                    <option value="WEEKEND_WORKSHOP">Weekend Workshop</option>
                </select>
            </label>
            <label>Search
                <input type="search" name="q" value="{{filters.q}}" placeholder="Title or description" />
            </label>
            <div>
                <button class="btn primary" type="submit">Apply</button>
                <a href="/courses" class="btn">Reset</a>
            </div>
        </form>
    </section>

    <div class="cards">
        {{#courses}}
        <article class="card">
            <h2><a href="/courses/{{id}}">{{title}}</a></h2>
            <p class="muted">Level: {{level}} • Type: {{type}} {{#allowDropIn}}• Drop-in OK{{/allowDropIn}}</p>
            <p>{{description}}</p>
            <p class="muted">Dates: {{startDate}} – {{endDate}}</p>
            <p class="muted">Next session: {{nextSession}} • Sessions: {{sessionsCount}}</p>
            <a href="/courses/{{id}}" class="btn primary">View & Book</a>
        </article>
        {{/courses}}

        {{^courses}}
        <p>No courses match your filters.</p>
        {{/courses}}
    </div>
</main>
{{> footer}}