
{{> head}}
{{> header}}
<main>
<article>
  <h1>{{course.title}}</h1>
  <p class="muted">
    Level: {{course.level}} • Type: {{course.type}} {{#course.allowDropIn}}• Drop-in available{{/course.allowDropIn}}
  </p>
  <p>{{course.description}}</p>
  <p class="muted">Dates: {{course.startDate}} – {{course.endDate}}</p>
  <p class="muted">Location: {{course.location}}</p>
  <p class="muted">Price: {{course.price}}</p>

  {{#isLoggedIn}}
  <section>
    <h2>Book the full course</h2>
    <form action="/courses/{{course.id}}/book" method="post">
      <button class="btn primary" type="submit">Book full course</button>
    </form>
  </section>
  {{/isLoggedIn}}

  {{^isLoggedIn}}
  <section>
    <p><a href="/auth/login">Login</a> or <a href="/auth/register">Register</a> to book this course.</p>
  </section>
  {{/isLoggedIn}}

  <section>
    <h2>Sessions</h2>
    <table class="table">
      <thead>
        <tr>
          <th>Start</th>
          <th>End</th>
          <th>Capacity</th>
          <th>Booked</th>
          <th>Remaining</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        {{#sessions}}
        <tr>
          <td>{{start}}</td>
          <td>{{end}}</td>
          <td>{{capacity}}</td>
          <td>{{booked}}</td>
          <td>{{remaining}}</td>
          <td>
            {{#isLoggedIn}}
            <form action="/sessions/{{id}}/book" method="post">
              <button class="btn" type="submit">Book this session</button>
            </form>
            {{/isLoggedIn}}
          </td>
        </tr>
        {{/sessions}}
      </tbody>
    </table>
  </section>
</article>
</main>
{{> footer}}
