
{{> head}}
{{> header}}
<main>
    <h1>{{title}}</h1>
    <form action="{{action}}" method="post">
        <label for="title">Course Title</label>
        <input type="text" id="title" name="title" value="{{course.title}}" required />

        <label for="level">Level</label>
        <select id="level" name="level">
            <option value="beginner" {{#course.level}}{{/course.level}}>Beginner</option>
            <option value="intermediate">Intermediate</option>
            <option value="advanced">Advanced</option>
        </select>

        <label for="type">Type</label>
        <select id="type" name="type">
            <option value="WEEKLY_BLOCK">Weekly Block</option>
            <option value="WEEKEND_WORKSHOP">Weekend Workshop</option>
        </select>

        <label for="location">Location</label>
        <input type="text" id="location" name="location" value="{{course.location}}" />

        <label for="price">Price (£)</label>
        <input type="number" id="price" name="price" value="{{course.price}}" step="0.01" min="0" />

        <label for="startDate">Start Date</label>
        <input type="date" id="startDate" name="startDate" value="{{course.startDate}}" required />

        <label for="endDate">End Date</label>
        <input type="date" id="endDate" name="endDate" value="{{course.endDate}}" required />

        <label for="description">Description</label>
        <textarea id="description" name="description" rows="4">{{course.description}}</textarea>

        <label for="allowDropIn">
            <input type="checkbox" id="allowDropIn" name="allowDropIn" {{#course.allowDropIn}}checked{{/course.allowDropIn}} />
            Allow Drop-ins
        </label>

        <button type="submit" class="btn primary">Save Course</button>
        <a href="/organiser/courses" class="btn">Cancel</a>
    </form>
</main>
{{> footer}}